# Copy this to .env and fill in your actual credentials.
# .env should be in .gitignore — NEVER commit real credentials.

# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
# (you need 2FA enabled on the account first)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your-app-password-here
SENDER_NAME=ThinkNeuro
SENDER_EMAIL=your.email@gmail.com

# Set to "true" to actually send emails. When "false", the script generates
# PDFs but only PRINTS what it would send. Use this for testing.
SEND_EMAILS=false
