# Copy this to .env and fill in your actual values.
# .env should be in .gitignore — NEVER commit real credentials.

# === Database ===
# For local development, leave this unset (defaults to SQLite).
# For production, set to your PostgreSQL connection string.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# === Flask ===
# Generate a random secret key for production: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=dev-secret-change-me

# === Email (SendGrid) ===
# Create a SendGrid account and generate an API key at
# https://app.sendgrid.com/settings/api_keys
# The key needs "Mail Send" permission.
SENDGRID_API_KEY=SG.your-api-key-here

# The FROM name and address that students will see. The sending domain
# must be verified in SendGrid (Settings > Sender Authentication).
SENDER_NAME=ThinkNeuro
SENDER_EMAIL=certificates@thinkneuro.org

# Set to "true" to actually send emails. When "false", PDFs are generated
# but emails are only PRINTED, not sent.
SEND_EMAILS=false

# === Auto-seed Admin ===
# On first startup, if no users exist, an admin account is created with these.
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=changeme
